# Casa Venturas — Environment Variables (TEMPLATE)
# Copy this to .env.local and fill in real values
# .env.local is gitignored — never commit real secrets

# --- Bókun REST API (server-side only, HMAC auth) ---
# Get from Bókun → Settings → Developer API → your key
BOKUN_ACCESS_KEY=your_access_key_here
BOKUN_SECRET_KEY=your_secret_key_here
# Channel UUID + product IDs are NON-SENSITIVE (embedded in widget URL).
# Use NEXT_PUBLIC_ so client components read them at build time.
# Get from Bókun → Sales Tools → Booking Channels → your channel UUID
NEXT_PUBLIC_BOKUN_CHANNEL_UUID=your_channel_uuid_here

# --- Bókun product IDs (one per tour) ---
# Get from Bókun → Products → open each one → copy ID
NEXT_PUBLIC_BOKUN_PRODUCT_EL_YUNQUE=
NEXT_PUBLIC_BOKUN_PRODUCT_CATAMARAN=
NEXT_PUBLIC_BOKUN_PRODUCT_SALSA=

# --- Custom checkout rollout flag ---
# disabled  — production default: BookingSidebar opens the hosted Bókun modal
# dev-mock  — CheckoutPanel renders but the submit route returns a fake success
# live      — CheckoutPanel + real Stripe Elements + real Bokun submit
# Keep both values aligned (server + client).
NEXT_PUBLIC_BOKUN_CHECKOUT_MODE=disabled
BOKUN_CHECKOUT_MODE=disabled

# --- Stripe publishable key (safe to expose — cannot charge, only tokenize) ---
# Get it from: Bokun → Settings → Payment Providers → Stripe → publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here

# --- Resend (contact + booking confirmation emails) ---
RESEND_API_KEY=your_resend_key_here
RESEND_FROM=hello@casaventuras.com

# --- n8n webhook (booking dispatch automation) ---
N8N_BOOKING_WEBHOOK=https://your-n8n-instance.com/webhook/booking

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=http://localhost:3737

# --- Perplexity API (optional — only for /audit-index-biz AI-search measurements) ---
# Format: pplx-<40 chars>. Get it from https://www.perplexity.ai/settings/api
# Used by CCS audit pipeline to check if Casa Venturas appears in Perplexity
# citations for ICP queries (e.g. "best private catamaran Vieques small group").
# Safe to leave empty — /audit-index-biz skips this volet gracefully.
PERPLEXITY_API_KEY=
