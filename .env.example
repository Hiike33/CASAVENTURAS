# Casa Venturas — Environment Variables
# Copy this to .env.local and fill in values

# Claude API (for Cavi chatbot)
ANTHROPIC_API_KEY=your_api_key_here

# Resend (for contact form + booking confirmation emails)
RESEND_API_KEY=your_resend_key_here
RESEND_FROM=hello@casaventuras.com

# n8n webhook URL (for booking dispatch automation)
N8N_BOOKING_WEBHOOK=https://your-n8n-instance.com/webhook/booking

# Site URL
NEXT_PUBLIC_SITE_URL=https://micasaventuras.com
