# local env files — ignore ALL env variants except public templates
# .env.example  → keys-only placeholder for newcomers
# .env.production → public NEXT_PUBLIC_* values inlined at build time
#                   (no secrets; real secrets live in wrangler secret put)
.env
.env.*
!.env.example
!.env.production

